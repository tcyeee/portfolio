---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="3D 模型交互" description="3D 模型交互演示">
  <div class="stage">
    <div class="rig">
      <div class="shadow"></div>
      <div class="console">
        <div class="face face--front">
          <div class="dial"></div>

          <div class="screen">
            <div class="screen__glow"></div>
            <span class="screen__label">PRESS START</span>
          </div>

          <div class="dpad">
            <span class="dpad__arrow dpad__arrow--up">▲</span>
            <span class="dpad__arrow dpad__arrow--right">▶</span>
            <span class="dpad__arrow dpad__arrow--down">▼</span>
            <span class="dpad__arrow dpad__arrow--left">◀</span>
          </div>

          <div class="btn btn--b"><span>B</span></div>
          <div class="btn btn--a"><span>A</span></div>

          <div class="grill">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>

        <div class="face face--right"></div>
        <div class="face face--left"></div>
        <div class="face face--top"></div>
        <div class="face face--bottom">
          <div class="port"></div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .stage {
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f4f0e6;
    border-radius: 24px;
    overflow: hidden;
    perspective: 1600px;
  }

  .rig {
    position: relative;
    width: 420px;
    height: 460px;
  }

  .shadow {
    position: absolute;
    left: 50%;
    bottom: -30px;
    width: 320px;
    height: 60px;
    background: radial-gradient(closest-side, rgba(20, 15, 5, 0.25), rgba(20, 15, 5, 0));
    transform: translate(-50%, 0) rotateX(90deg) scale(var(--shadow-scale, 1));
    transition: none;
    filter: blur(2px);
  }

  .console {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: rotateX(var(--rx, 8deg)) rotateY(var(--ry, -16deg));
    will-change: transform;
  }

  .face {
    position: absolute;
    background: linear-gradient(155deg, #fdfbf5 0%, #eee8da 100%);
    border-radius: 42px;
  }

  .face--front {
    inset: 0;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  .face--right {
    top: 0;
    left: 100%;
    width: 46px;
    height: 100%;
    transform-origin: left center;
    transform: rotateY(-90deg);
    background: linear-gradient(180deg, #e4ddcc 0%, #d3cab5 100%);
    border-radius: 0 42px 42px 0;
  }

  .face--left {
    top: 0;
    right: 100%;
    width: 46px;
    height: 100%;
    transform-origin: right center;
    transform: rotateY(90deg);
    background: linear-gradient(180deg, #eee7d8 0%, #ddd4c0 100%);
    border-radius: 42px 0 0 42px;
  }

  .face--top {
    left: 0;
    bottom: 100%;
    width: 100%;
    height: 46px;
    transform-origin: center bottom;
    transform: rotateX(90deg);
    background: linear-gradient(90deg, #fffdf8 0%, #efe9db 100%);
    border-radius: 42px 42px 0 0;
  }

  .face--bottom {
    left: 0;
    top: 100%;
    width: 100%;
    height: 46px;
    transform-origin: center top;
    transform: rotateX(-90deg);
    background: linear-gradient(90deg, #ddd4c0 0%, #cabfa6 100%);
    border-radius: 0 0 42px 42px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .port {
    margin-top: 10px;
    width: 64px;
    height: 10px;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.18);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.3);
  }

  .dial {
    position: absolute;
    top: 150px;
    right: -6px;
    width: 22px;
    height: 34px;
    border-radius: 8px;
    background: linear-gradient(90deg, #1c1c1e, #3a3a3d);
    box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .screen {
    position: absolute;
    top: 34px;
    left: 34px;
    right: 34px;
    height: 232px;
    border-radius: 20px;
    background: #111;
    padding: 12px;
    box-shadow:
      inset 0 0 0 2px rgba(255, 255, 255, 0.05),
      0 10px 24px rgba(0, 0, 0, 0.25);
  }

  .screen__glow {
    position: absolute;
    inset: 12px;
    border-radius: 10px;
    background: linear-gradient(115deg, #ff8a5c 0%, #ff8a5c 42%, #22c1c9 58%, #22c1c9 100%);
    background-size: 220% 220%;
    animation: screen-shift 6s ease-in-out infinite;
    overflow: hidden;
  }

  .screen__glow::before,
  .screen__glow::after {
    content: '';
    position: absolute;
    top: -10%;
    bottom: -10%;
    width: 55%;
    background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0) 70%);
  }

  .screen__glow::before {
    left: -8%;
  }

  .screen__glow::after {
    right: -8%;
  }

  .screen__label {
    position: absolute;
    left: 50%;
    bottom: 22px;
    transform: translateX(-50%);
    font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 3px;
    color: #fff;
    text-shadow: 0 0 6px rgba(255, 255, 255, 0.6);
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes screen-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @keyframes blink {
    0%,
    55% {
      opacity: 1;
    }
    56%,
    100% {
      opacity: 0;
    }
  }

  .dpad {
    position: absolute;
    left: 46px;
    bottom: 64px;
    width: 92px;
    height: 92px;
    background: #2b2b2e;
    clip-path: polygon(34% 0%, 66% 0%, 66% 34%, 100% 34%, 100% 66%, 66% 66%, 66% 100%, 34% 100%, 34% 66%, 0% 66%, 0% 34%, 34% 34%);
    box-shadow:
      0 6px 10px rgba(0, 0, 0, 0.25),
      inset 0 -3px 4px rgba(0, 0, 0, 0.4),
      inset 0 2px 3px rgba(255, 255, 255, 0.08);
  }

  .dpad__arrow {
    position: absolute;
    color: #86868c;
    font-size: 10px;
    line-height: 1;
  }

  .dpad__arrow--up {
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
  }

  .dpad__arrow--down {
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
  }

  .dpad__arrow--left {
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
  }

  .dpad__arrow--right {
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
  }

  .btn {
    position: absolute;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: ui-monospace, monospace;
    font-weight: 700;
    color: rgba(0, 0, 0, 0.55);
    box-shadow:
      0 6px 10px rgba(0, 0, 0, 0.2),
      inset 0 -4px 6px rgba(0, 0, 0, 0.15),
      inset 0 3px 4px rgba(255, 255, 255, 0.5);
  }

  .btn--a {
    width: 52px;
    height: 52px;
    right: 62px;
    bottom: 56px;
    background: radial-gradient(circle at 35% 30%, #ffe1a3, #f3c15f);
  }

  .btn--b {
    width: 44px;
    height: 44px;
    right: 40px;
    bottom: 118px;
    background: radial-gradient(circle at 35% 30%, #f2c9ee, #d99bd0);
  }

  .grill {
    position: absolute;
    right: 40px;
    bottom: 30px;
    width: 34px;
    height: 20px;
  }

  .grill span {
    position: absolute;
    width: 100%;
    height: 2px;
    background: rgba(0, 0, 0, 0.15);
    transform: rotate(-35deg);
  }

  .grill span:nth-child(1) {
    top: 0;
  }
  .grill span:nth-child(2) {
    top: 6px;
  }
  .grill span:nth-child(3) {
    top: 12px;
  }
  .grill span:nth-child(4) {
    top: 18px;
  }
</style>

<script>
  ;(function () {
    const stage = document.querySelector('.stage') as HTMLElement
    const consoleEl = document.querySelector('.console') as HTMLElement
    const shadowEl = document.querySelector('.shadow') as HTMLElement

    const REST = { rx: 8, ry: -16 }
    const MAX_RX = 22
    const MAX_RY = 34
    const EASE = 0.09

    let target = { ...REST }
    let current = { ...REST }
    let hovering = false

    function updateTarget(clientX: number, clientY: number) {
      const rect = stage.getBoundingClientRect()
      const px = (clientX - rect.left) / rect.width - 0.5 // -0.5..0.5
      const py = (clientY - rect.top) / rect.height - 0.5

      target.ry = REST.ry + px * MAX_RY * 2
      target.rx = REST.rx - py * MAX_RX * 2
    }

    stage.addEventListener('mousemove', (e) => {
      hovering = true
      updateTarget(e.clientX, e.clientY)
    })

    stage.addEventListener('mouseleave', () => {
      hovering = false
      target = { ...REST }
    })

    stage.addEventListener(
      'touchmove',
      (e) => {
        const t = e.touches[0]
        if (!t) return
        hovering = true
        updateTarget(t.clientX, t.clientY)
      },
      { passive: true },
    )

    stage.addEventListener('touchend', () => {
      hovering = false
      target = { ...REST }
    })

    function tick() {
      current.rx += (target.rx - current.rx) * EASE
      current.ry += (target.ry - current.ry) * EASE

      consoleEl.style.setProperty('--rx', current.rx.toFixed(2) + 'deg')
      consoleEl.style.setProperty('--ry', current.ry.toFixed(2) + 'deg')

      // shadow shrinks/spreads a little as the console tilts away from rest
      const drift = Math.abs(current.ry - REST.ry) / MAX_RY
      const scale = 1 - drift * 0.18
      shadowEl.style.setProperty('--shadow-scale', scale.toFixed(3))

      requestAnimationFrame(tick)
    }

    requestAnimationFrame(tick)
  })()
</script>
