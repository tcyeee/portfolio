---
import Layout from '../layouts/Layout.astro'
---

<Layout title="页面未找到">
  <div class="container mx-auto px-4 py-32 max-w-2xl text-center">
    <p class="text-7xl font-bold text-primary-600 dark:text-primary-400 mb-4">404</p>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">页面走丢了</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">你访问的页面不存在或已被移动。</p>
    <a
      href="/"
      class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
      返回首页
    </a>
  </div>
</Layout>
